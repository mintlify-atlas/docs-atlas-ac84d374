  "keyFeatures": [
    "Flexible board filtering with regex blacklist/whitelist",
    "Selective media downloading (text, thumbnails, full media)",
    "Asagi schema support for SQLite and MySQL",
    "Duplicate media detection and MD5 verification",
    "File scanner tool for metadata extraction",
    "Configurable cooldowns and rate limiting"
  ],
  "publicApiSurface": [
    "main.py - Main archiver entry point",
    "scanner/scanner.py - Media file scanner CLI",
    "configs.py - Configuration file",
    "db.ritual.RitualDb - Database interface",
    "Archive - Archive.json fetcher",
    "Catalog - Catalog.json processor",
    "Filter - Thread and media filtering",
    "Posts - Post fetching and persistence",
    "Fetcher - HTTP client with rate limiting",
    "State - Thread state management"
  ]
